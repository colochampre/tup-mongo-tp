<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MongoDB Explorer</title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="icon" type="image/svg+xml" href="/mongodb-leaf.svg" />
</head>
<body>
  <canvas id="matrix-canvas"></canvas>

  <div class="container">
    <header>
      <h1 class="glow">> show collections</h1>
      <p class="subtitle">Base de Datos: <span class="highlight">tup_mongo_tp</span></p>
    </header>

    <% if (error) { %>
      <div class="flash flash-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="flash flash-success"><%= success %></div>
    <% } %>

    <section class="create-collection">
      <h2>// Crear colección</h2>
      <form action="/collections" method="POST" class="create-form">
        <span class="bracket">{</span>
        <div class="form-group inline">
          <label><span class="jkey">"collection"</span>:</label>
          <input type="text" name="name" class="jstr" required
            pattern="[a-zA-Z_][a-zA-Z0-9_]*"
            placeholder='"nombre_coleccion"' />
        </div>
        <span class="bracket">}</span>
        <button type="submit" class="btn-execute">db.createCollection(...)</button>
      </form>
    </section>

    <section class="collections-grid">
      <h2>// Colecciones disponibles</h2>
      <div class="cards-wrapper">
        <% collections.forEach(col => { %>
        <div class="collection-card" onclick="location.href='/collections/<%= col.name %>'">
          <div class="card-header">
            <span class="bracket">{</span>
          </div>
          <div class="card-body">
            <div class="field">
              <span class="key">"collection"</span>: <span class="string">"<%= col.name %>"</span>
            </div>
            <div class="field">
              <span class="key">"label"</span>: <span class="string">"<%= col.label %>"</span>
            </div>
            <div class="field">
              <span class="key">"documentos"</span>: <span class="number"><%= col.count %></span>
            </div>
          </div>
          <div class="card-footer">
            <span class="bracket">}</span>
            <span class="action">→ VER DOCUMENTOS</span>
            <form action="/collections/<%= col.name %>/delete" method="POST"
              onclick="event.stopPropagation()"
              onsubmit="return confirm('¿Ejecutar db.<%= col.name %>.drop()?');">
              <button type="submit" class="btn-delete">[ x ]</button>
            </form>
          </div>
        </div>
        <% }) %>
      </div>
    </section>
  </div>

  <script src="/matrix.js"></script>
</body>
</html>
